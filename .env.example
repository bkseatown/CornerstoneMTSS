# Cornerstone MTSS Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================
# Server Configuration
# ============================================================

# Application port
PORT=3000

# Server host (0.0.0.0 for all interfaces, localhost for local only)
HOST=0.0.0.0

# Node environment (development or production)
NODE_ENV=development

# ============================================================
# Allowed Origins (CORS)
# ============================================================

# Comma-separated list of allowed origins for WebSocket and API
ALLOWED_ORIGINS=http://127.0.0.1:4174,http://localhost:4174,http://localhost:3000

# ============================================================
# Database Configuration
# ============================================================

# MongoDB connection (for session persistence)
# Format: mongodb://[username:password@]host[:port][/database]
MONGODB_URI=mongodb://localhost:27017/cornerstone-mtss

# PostgreSQL connection (alternative to MongoDB)
# Format: postgresql://[user[:password]@][netloc][:port][/database]
DATABASE_URL=

# Database connection pool size
DB_POOL_SIZE=10

# ============================================================
# Session Management
# ============================================================

# Session timeout in milliseconds (24 hours)
SESSION_TIMEOUT=86400000

# Session cleanup interval in milliseconds (1 hour)
CLEANUP_INTERVAL=3600000

# Max sessions per user
MAX_SESSIONS_PER_USER=5

# ============================================================
# Authentication & Security
# ============================================================

# JWT secret for token signing
JWT_SECRET=your-secret-key-change-in-production

# JWT expiration time
JWT_EXPIRY=7d

# Enable session encryption
ENCRYPT_SESSIONS=true

# ============================================================
# Email Configuration (for notifications)
# ============================================================

# SMTP server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# From address for system emails
MAIL_FROM=noreply@cornerstone.edu

# Parent notification email template
PARENT_EMAIL_TEMPLATE=parent-notification

# ============================================================
# Third-Party Integrations
# ============================================================

# Analytics service
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=

# Error tracking (Sentry, etc.)
ERROR_TRACKING_ENABLED=false
ERROR_TRACKING_DSN=

# ============================================================
# Voice Analysis (Web Audio API)
# ============================================================

# Audio processing sample rate (Hz)
AUDIO_SAMPLE_RATE=16000

# Audio chunk duration (ms)
AUDIO_CHUNK_DURATION=1024

# FFT size for frequency analysis
FFT_SIZE=2048

# ============================================================
# 3D Rendering (Babylon.js)
# ============================================================

# Enable shadow rendering
ENABLE_SHADOWS=true

# Shadow map resolution
SHADOW_MAP_SIZE=2048

# Enable post-processing effects
ENABLE_POST_PROCESSING=true

# LOD distance thresholds
LOD_DISTANCE_HIGH=50
LOD_DISTANCE_MEDIUM=100
LOD_DISTANCE_LOW=150

# ============================================================
# Accessibility
# ============================================================

# Enable accessibility controls
A11Y_ENABLED=true

# Default accessibility mode (standard, dyslexia, high-contrast, low-vision)
A11Y_DEFAULT_MODE=standard

# Default font scale (1.0 = 100%)
A11Y_DEFAULT_FONT_SCALE=1.0

# ============================================================
# Development Tools
# ============================================================

# Enable debug logging
DEBUG=false
DEBUG_NAMESPACE=*

# Enable development server hot reload
HOT_RELOAD=true

# Enable mock data for testing
USE_MOCK_DATA=false

# ============================================================
# Monitoring & Logging
# ============================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable console logging
CONSOLE_LOG=true

# Enable file logging
FILE_LOG=false

# Log file path
LOG_FILE_PATH=./logs/app.log

# Performance monitoring
MONITOR_PERFORMANCE=true

# Memory limit (MB) before warning
MEMORY_LIMIT_WARNING=512

# ============================================================
# Feature Flags
# ============================================================

# Enable real-time collaboration
FEATURE_COLLABORATION=true

# Enable voice analysis
FEATURE_VOICE_ANALYSIS=true

# Enable 3D environments
FEATURE_3D=true

# Enable advanced accessibility
FEATURE_A11Y=true

# Enable adaptive recommendations
FEATURE_ADAPTIVE_AI=true

# Enable parent dashboard
FEATURE_PARENT_DASHBOARD=true
