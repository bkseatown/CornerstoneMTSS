# Cornerstone MTSS Production Environment Configuration
# ⚠️ SECURITY WARNING: This file contains sensitive configuration
# Copy to .env.production and update with real production values
# NEVER commit actual .env.production with secrets to version control

# ============================================================
# Server Configuration
# ============================================================

# Production port
PORT=3000

# Production server host (bind to all interfaces for load balancer)
HOST=0.0.0.0

# Production environment
NODE_ENV=production

# ============================================================
# Allowed Origins (CORS) — MUST INCLUDE YOUR DOMAIN
# ============================================================

# ⚠️ CRITICAL: Update with your actual production domains
ALLOWED_ORIGINS=https://cornerstone.edu,https://www.cornerstone.edu,https://bkseatown.github.io

# ============================================================
# Database Configuration — MUST BE EXTERNAL SERVICE
# ============================================================

# ⚠️ CRITICAL: Use managed MongoDB (Atlas, etc.) in production, NOT localhost
# Example: mongodb+srv://user:password@cluster0.mongodb.net/cornerstone-mtss?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/cornerstone-mtss?retryWrites=true&w=majority

# Alternative: PostgreSQL (with SSL)
# Example: postgresql://user:password@host:5432/cornerstone_mtss?sslmode=require
DATABASE_URL=

# Database connection pool size (for high concurrency)
DB_POOL_SIZE=20

# ============================================================
# Session Management
# ============================================================

# Session timeout in milliseconds (24 hours)
SESSION_TIMEOUT=86400000

# Session cleanup interval (1 hour)
CLEANUP_INTERVAL=3600000

# Max sessions per user
MAX_SESSIONS_PER_USER=5

# ============================================================
# Authentication & Security — GENERATE STRONG VALUES
# ============================================================

# ⚠️ CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generated-secret-key-min-32-chars

# JWT expiration time
JWT_EXPIRY=7d

# Enable session encryption (always true in production)
ENCRYPT_SESSIONS=true

# ============================================================
# TLS/SSL Configuration
# ============================================================

# Enable HTTPS/WSS (WebSocket Secure)
ENABLE_TLS=true

# Path to TLS certificate (for reverse proxy, set via nginx/Apache)
TLS_CERT_PATH=/etc/ssl/certs/cornerstone.edu.crt
TLS_KEY_PATH=/etc/ssl/private/cornerstone.edu.key

# ============================================================
# Email Configuration (for parent notifications)
# ============================================================

# ⚠️ CRITICAL: Use app-specific password (not Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cornerstone-notifications@gmail.com
SMTP_PASS=[app-specific-password]

# From address for system emails
MAIL_FROM=notifications@cornerstone.edu

# Parent notification email template
PARENT_EMAIL_TEMPLATE=parent-notification

# Batch email sending (prevent rate limiting)
EMAIL_BATCH_SIZE=50
EMAIL_BATCH_DELAY=1000

# ============================================================
# Third-Party Integrations
# ============================================================

# Analytics service (Mixpanel, Amplitude, etc.)
ANALYTICS_ENABLED=true
ANALYTICS_API_KEY=[your-analytics-key]

# Error tracking (Sentry)
ERROR_TRACKING_ENABLED=true
ERROR_TRACKING_DSN=[your-sentry-dsn]

# Performance monitoring
MONITOR_PERFORMANCE=true

# ============================================================
# Voice Analysis
# ============================================================

# Audio processing sample rate
AUDIO_SAMPLE_RATE=16000

# Audio chunk duration
AUDIO_CHUNK_DURATION=1024

# FFT size for frequency analysis
FFT_SIZE=2048

# ============================================================
# 3D Rendering
# ============================================================

# Enable shadow rendering
ENABLE_SHADOWS=true

# Shadow map resolution (higher for better quality, lower for performance)
SHADOW_MAP_SIZE=2048

# Enable post-processing effects
ENABLE_POST_PROCESSING=true

# LOD distance thresholds
LOD_DISTANCE_HIGH=50
LOD_DISTANCE_MEDIUM=100
LOD_DISTANCE_LOW=150

# ============================================================
# Accessibility
# ============================================================

# Enable accessibility controls
A11Y_ENABLED=true

# Default accessibility mode
A11Y_DEFAULT_MODE=standard

# Default font scale
A11Y_DEFAULT_FONT_SCALE=1.0

# ============================================================
# Development Tools (DISABLED IN PRODUCTION)
# ============================================================

# Disable debug logging in production
DEBUG=false

# Disable hot reload
HOT_RELOAD=false

# Disable mock data
USE_MOCK_DATA=false

# ============================================================
# Monitoring & Logging
# ============================================================

# Log level (use 'warn' or 'error' in production)
LOG_LEVEL=warn

# Enable console logging
CONSOLE_LOG=true

# Enable file logging to persistent storage
FILE_LOG=true

# ⚠️ CRITICAL: Use absolute path to persistent storage (not /tmp)
LOG_FILE_PATH=/var/log/cornerstone/app.log

# Log rotation (daily)
LOG_ROTATION=daily

# Memory limit before warning/restart
MEMORY_LIMIT_WARNING=512
MEMORY_LIMIT_RESTART=1024

# Performance monitoring threshold (ms)
SLOW_REQUEST_THRESHOLD=1000

# ============================================================
# Backup & Recovery
# ============================================================

# Enable automated backups
BACKUPS_ENABLED=true

# Backup frequency (daily, weekly)
BACKUP_FREQUENCY=daily

# Backup storage (S3, GCS, etc.)
BACKUP_STORAGE=s3

# ⚠️ CRITICAL: Provide cloud credentials
BACKUP_S3_BUCKET=[your-backup-bucket]
BACKUP_S3_REGION=[aws-region]
BACKUP_S3_ACCESS_KEY=[your-access-key]
BACKUP_S3_SECRET_KEY=[your-secret-key]

# Retention policy (days)
BACKUP_RETENTION_DAYS=90

# ============================================================
# Feature Flags
# ============================================================

# Enable real-time collaboration
FEATURE_COLLABORATION=true

# Enable voice analysis
FEATURE_VOICE_ANALYSIS=true

# Enable 3D environments
FEATURE_3D=true

# Enable advanced accessibility
FEATURE_A11Y=true

# Enable adaptive recommendations
FEATURE_ADAPTIVE_AI=true

# Enable parent dashboard
FEATURE_PARENT_DASHBOARD=true

# ============================================================
# Rate Limiting & Security
# ============================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Requests per window
RATE_LIMIT_REQUESTS=100

# Window duration (seconds)
RATE_LIMIT_WINDOW=60

# Enable CORS preflight caching
CORS_PREFLIGHT_CACHE=3600

# ============================================================
# CDN Configuration
# ============================================================

# Enable CDN for static assets
CDN_ENABLED=true

# CDN URL prefix (e.g., https://cdn.cornerstone.edu)
CDN_URL=https://cdn.cornerstone.edu

# ============================================================
# Admin Configuration
# ============================================================

# Admin dashboard access token
ADMIN_TOKEN=[generate-secure-token]

# Admin IP whitelist (comma-separated)
ADMIN_IP_WHITELIST=

# ============================================================
# Deployment Checklist
# ============================================================

# Before deploying, ensure:
# [ ] All sensitive values are generated (JWT_SECRET, etc.)
# [ ] Database is provisioned and accessible
# [ ] Email credentials are tested
# [ ] Analytics and error tracking are configured
# [ ] Backup storage is provisioned
# [ ] SSL certificates are installed
# [ ] Logging directory exists and is writable
# [ ] File is added to .gitignore (NEVER commit secrets)
# [ ] Permissions are restricted (chmod 600 .env.production)
